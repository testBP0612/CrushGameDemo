{
  "schema_version": "1.0",
  "_comment": "數值單一真實來源。Codex 禁止把這些數字寫死在 script。欄位定義見 Docs/06_DATA_SCHEMA.md。",
  "currency": {
    "id": "coins",
    "display_name_key": "currency_coins",
    "starting_balance": 10000,
    "min_bet": 10,
    "max_bet": 5000,
    "bet_step": 10,
    "default_bet": 50,
    "quick_bet_options": [10, 50, 100, 500, 1000, 2000, 3000, 5000]
  },
  "payout": {
    "_comment": "current_payout = bet * multiplier_at_stage(stage_cleared)。stage 從 1 起算，代表已擊敗的怪物數。",
    "rounding": "floor",
    "base_multiplier_at_stage_0": 1.0
  },
  "multiplier_curve": [
    { "stage": 1, "multiplier": 1.25 },
    { "stage": 2, "multiplier": 1.62 },
    { "stage": 3, "multiplier": 2.12 },
    { "stage": 4, "multiplier": 2.90 },
    { "stage": 5, "multiplier": 4.10 },
    { "stage": 6, "multiplier": 6.00 },
    { "stage": 7, "multiplier": 9.10 },
    { "stage": 8, "multiplier": 14.20 },
    { "stage": 9, "multiplier": 23.00 },
    { "stage": 10, "multiplier": 38.00 }
  ],
  "multiplier_random": {
    "_comment": "D-019 每局隨機倍率盤。enabled=false 時完全走 multiplier_curve 原值（回退路徑）。下注確認時以 multiplier_curve 為基準擲一次本局盤：抖動由 stage_1 線性放大到 stage_max，並強制單調遞增（本關 ≥ 前關 × min_growth_ratio）。success_rate 不連動。",
    "enabled": true,
    "jitter_pct_stage_1": 0.10,
    "jitter_pct_stage_max": 0.30,
    "min_growth_ratio": 1.15,
    "round_decimals": 2
  },
  "random_events": {
    "huye": {
      "_comment": "D-022 虎爺救援事件。每次挑戰用獨立 RNG 擲骰；觸發時跳過勝負骰、強制逆轉勝，並把該關收益增額額外加一份保留至結算。force_trigger 僅供展示/錄影。",
      "enabled": true,
      "trigger_probability": 0.05,
      "force_trigger": false,
      "reward_mode": "stage_increment_x2"
    }
  },
  "danger_display": {
    "_comment": "D-019 危險度分級（取代血條）。依即將挑戰關卡的 success_rate 由上往下取第一個符合（success_rate ≥ min_success_rate）的等級。",
    "max_level": 5,
    "levels": [
      { "min_success_rate": 0.80, "level": 1 },
      { "min_success_rate": 0.60, "level": 2 },
      { "min_success_rate": 0.45, "level": 3 },
      { "min_success_rate": 0.30, "level": 4 },
      { "min_success_rate": 0.00, "level": 5 }
    ]
  },
  "success_rate_curve": [
    { "stage": 1, "success_rate": 0.90 },
    { "stage": 2, "success_rate": 0.83 },
    { "stage": 3, "success_rate": 0.76 },
    { "stage": 4, "success_rate": 0.68 },
    { "stage": 5, "success_rate": 0.60 },
    { "stage": 6, "success_rate": 0.52 },
    { "stage": 7, "success_rate": 0.45 },
    { "stage": 8, "success_rate": 0.38 },
    { "stage": 9, "success_rate": 0.31 },
    { "stage": 10, "success_rate": 0.24 }
  ],
  "cashout_rules": {
    "_comment": "撤退領取目前收益（current_payout）；戰敗則失去本局所有（含已累積收益），僅扣初始下注的損益依 loss_mode。",
    "can_cashout_after_stage": 1,
    "loss_mode": "lose_current_payout_and_bet",
    "cashout_returns": "current_payout"
  },
  "stage_progression": {
    "max_stage": 10,
    "loop_after_max": false,
    "_comment": "MVP 最多 10 關；到第 10 關清空後視為通關，強制結算。loop_after_max 為 Future 擴充點。"
  },
  "background_zones": {
    "_comment": "分區背景（資料驅動，可擴充）。依『即將挑戰的關卡』落在哪個 zone 選背景。zones 須涵蓋 1~max_stage；缺圖時 Codex 依 fallback_background_id 再退到漸層 placeholder，不可崩。",
    "default_background_id": "background_battle_001",
    "fallback_background_id": "background_battle_001",
    "zones": [
      { "from_stage": 1, "to_stage": 3, "background_id": "background_battle_001" },
      { "from_stage": 4, "to_stage": 6, "background_id": "background_battle_002" },
      { "from_stage": 7, "to_stage": 10, "background_id": "background_battle_003" }
    ]
  }
}
