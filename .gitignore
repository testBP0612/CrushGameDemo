# Godot 4+ specific ignores
.godot/
.import/
.nomedia
export.cfg
export_credentials.cfg
*.tmp

# Android exports
/android/
/export/web/

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# H5 / Web export 輸出
/export/
/build/
*.wasm
*.pck

# 美術候選稿不進 repo（只保留 Assets/final 與 placeholders）
# generated/ 為可選暫存區，請勿提交大量探索稿
Assets/generated/*
!Assets/generated/README.md
!Assets/generated/.gdkeep

# 驗證截圖 / 工具中間產物（非遊戲本體，不進 repo）
# 例：Codex 驗收截圖、agent-sprite-forge 的 raw-sheet 等中間檔
/Artifacts/
/validation_screenshots/
/ValidationScreenshots/

# Firebase deploy cache
Firebase/.firebase/

# Firebase CLI cache (repo root)
.firebase/
