rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // D-015 / Docs/08 §四：只有本人能讀寫自己的文件，其他一律拒絕。
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // D-016 / Docs/08 §七：排行榜——登入可讀，僅本人可寫，型別 + 單調遞增 + 上限守門。
    // create/update 才有 request.resource.data 可驗；delete 允許本人（清測試資料/退榜）。
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.display_name is string
        && request.resource.data.best_payout is int
        && request.resource.data.best_payout >= 0
        && request.resource.data.best_payout <= 1000000000
        && (!exists(/databases/$(database)/documents/leaderboard/$(uid))
            || request.resource.data.best_payout >= resource.data.best_payout);
      allow delete: if request.auth != null && request.auth.uid == uid;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
