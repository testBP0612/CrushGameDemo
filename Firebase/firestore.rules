rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // D-015 / Docs/08 §四：只有本人能讀寫自己的文件，其他一律拒絕。
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
